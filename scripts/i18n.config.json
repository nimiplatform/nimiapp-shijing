{
  "supportedLocales": ["en", "zh"],
  "audit": {
    "scopeDirs": ["src/shell", "src/product"],
    "extensions": [".ts", ".tsx"],
    "excludePathPatterns": [
      "/test/",
      ".test.",
      ".spec.",
      "src/shell/locales/",
      "src/product/i18n/",
      "src/product/astrology/",
      "src/product/conversations/conversation-chat-bridge.ts",
      "src/product/concern-tags/concern-presets.ts",
      "src/product/datetime/friendly-time.ts",
      "src/product/reading/",
      "src/product/tabs/shared/method-evidence-chips.ts",
      "src/product/tabs/shared/ziwei-astrolabe.tsx"
    ],
    "knownDebtPathPatterns": [
      "src/product/tabs/yuejing-tab.tsx",
      "src/product/tabs/nianjing-tab.tsx",
      "src/product/tabs/nianjing/nianjing-event-recorder.tsx",
      "src/product/natal/lunar-birth-date-picker.tsx",
      "src/product/natal/birth-time-picker.tsx"
    ],
    "allowTextPatterns": [
      "^-$",
      "^--$",
      "^x$",
      "^X$",
      "^Nimi$",
      "^ShiJing$",
      "^SHIJING$",
      "^Runtime$",
      "^Runtime AI$",
      "^AI$",
      "^ULID$",
      "^UTC$",
      "^GMT$",
      "^IANA$",
      "^JSON$",
      "^[A-Z0-9_]+$",
      "^[0-9]+$",
      "^[0-9]+/[0-9]+$",
      "^[a-z][a-z0-9]*(?:_[a-z0-9]+)+$",
      "^(high|medium|low|active|archived|manual|rijing|yuejing|nianjing|shijing)$"
    ]
  }
}
