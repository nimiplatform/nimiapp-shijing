{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "outDir": "dist-electron",
    "rootDir": ".",
    "types": [
      "node",
      "electron"
    ]
  },
  "include": [
    "src-electron/**/*.ts",
    "src-electron/**/*.cts",
    "src/contracts/app-identity.ts"
  ]
}
